{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run FastAPI Backend (Port 8001)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app:app",
                "--reload",
                "--host",
                "127.0.0.1",
                "--port",
                "8002"
            ],
            "cwd": "${workspaceFolder}/mediAI/backend",
            "jinja": true,
            "python": "${workspaceFolder}/mediAI/venv/Scripts/python.exe"
        },
        {
            "name": "Run Database Migrations",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/mediAI/backend/migrate.py",
            "cwd": "${workspaceFolder}/mediAI/backend",
            "python": "${workspaceFolder}/mediAI/venv/Scripts/python.exe"
        },
        {
            "name": "Backup Database",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/mediAI/database/backup_database.py",
            "cwd": "${workspaceFolder}/mediAI",
            "python": "${workspaceFolder}/mediAI/venv/Scripts/python.exe"
        },
        {
            "name": "Start SSH/Localtunnel Tunnel",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/mediAI/start_tunnel.py",
            "cwd": "${workspaceFolder}/mediAI",
            "python": "${workspaceFolder}/mediAI/venv/Scripts/python.exe"
        }
    ]
}
